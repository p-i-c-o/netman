#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NETMAN_HOME="${NETMAN_HOME:-$SCRIPT_DIR}"
CONFIG_DIR="${NETMAN_CONFIG_DIR:-$NETMAN_HOME/profiles}"
RESOLV_CONF="${NETMAN_RESOLV_CONF:-/etc/resolv.conf}"
APPLIER_CMD="${NETMAN_APPLIER_CMD:-/usr/local/sbin/netman-apply}"
BACKUP_DIR="${NETMAN_BACKUP_DIR:-$NETMAN_HOME/backups}"
BACKUP_LIMIT="${NETMAN_BACKUP_LIMIT:-5}"
TEST_MODE=0
JSON_MODE=0

C_RESET=""
C_YELLOW=""
C_CYAN=""

setup_colors() {
  if [[ -t 1 && -z "${NO_COLOR:-}" ]] && command -v tput >/dev/null 2>&1; then
    C_RESET="$(tput sgr0)"
    C_YELLOW="$(tput setaf 3)"
    C_CYAN="$(tput setaf 6)"
  fi
}

setup_colors

usage() {
  cat <<USAGE
Usage:
  netman [--test] [--json]                    Show current profile
  netman [--test] [--json] set <profile>      Apply a profile
  netman [--test] [--json] list               List profile names
  netman [--test] [--json] edit <profile>     Open profile in \$EDITOR
  netman [--test] [--json] create <name> --dns <ip> [--dns <ip> ...] [--subnet <cidr>]
                                               Create a new profile file
  netman [--test] [--json] rollback           Restore most recent backup

Default paths:
  Netman home:        $NETMAN_HOME
  Profiles directory: $CONFIG_DIR
  DNS target file:    $RESOLV_CONF
  Backup directory:   $BACKUP_DIR (max $BACKUP_LIMIT kept)
  Sudo helper:        $APPLIER_CMD

Test mode (--test):
  DNS target becomes: $NETMAN_HOME/DEMO
  Backups are saved as: $BACKUP_DIR/test-*.bak

Environment variables:
  NETMAN_HOME, NETMAN_CONFIG_DIR, NETMAN_RESOLV_CONF, NETMAN_APPLIER_CMD,
  NETMAN_BACKUP_DIR, NETMAN_BACKUP_LIMIT, EDITOR
USAGE
}

json_escape() {
  sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' -e ':a;N;$!ba;s/\n/\\n/g' <<<"$1"
}

profile_subnet() {
  local profile="$1"
  local profile_path="$CONFIG_DIR/$profile"
  local subnet

  [[ -f "$profile_path" ]] || return 1

  subnet="$(grep -Eo '([0-9]{1,3}\.){3}[0-9]{1,3}/[0-9]{1,2}' "$profile_path" | head -n1 || true)"
  [[ -n "$subnet" ]] || return 1

  printf '%s\n' "$subnet"
}

list_profiles() {
  [[ -d "$CONFIG_DIR" ]] || return 1
  find "$CONFIG_DIR" -maxdepth 1 -type f -printf '%f\n' | sort
}

detect_active_profile() {
  [[ -f "$RESOLV_CONF" && -d "$CONFIG_DIR" ]] || return 1

  local profile
  while IFS= read -r profile; do
    if cmp -s "$RESOLV_CONF" "$CONFIG_DIR/$profile"; then
      printf '%s\n' "$profile"
      return 0
    fi
  done < <(list_profiles)

  return 1
}

emit_status() {
  local profile="$1"
  local subnet="$2"

  if [[ "$JSON_MODE" -eq 1 ]]; then
    printf '{"action":"status","profile":"%s","subnet":"%s"}\n' \
      "$(json_escape "$profile")" "$(json_escape "$subnet")"
    return 0
  fi

  if [[ "$profile" == "custom/unknown" ]]; then
    echo "Current: custom/unknown"
  else
    echo "Current: $profile (${C_YELLOW}${subnet}${C_RESET})"
  fi
}

emit_swap() {
  local profile="$1"
  local subnet="$2"

  if [[ "$JSON_MODE" -eq 1 ]]; then
    printf '{"action":"swap","profile":"%s","subnet":"%s","test":%s}\n' \
      "$(json_escape "$profile")" "$(json_escape "$subnet")" "$( [[ "$TEST_MODE" -eq 1 ]] && echo true || echo false )"
    return 0
  fi

  if [[ "$TEST_MODE" -eq 1 ]]; then
    echo "${C_CYAN}[TEST]${C_RESET} Swapped to ${C_YELLOW}${subnet}${C_RESET} subnet."
  else
    echo "Swapped to ${C_YELLOW}${subnet}${C_RESET} subnet."
  fi
}

emit_error() {
  local msg="$1"
  if [[ "$JSON_MODE" -eq 1 ]]; then
    printf '{"action":"error","message":"%s"}\n' "$(json_escape "$msg")" >&2
  else
    echo "$msg" >&2
  fi
}

backup_prefix() {
  if [[ "$TEST_MODE" -eq 1 ]]; then
    printf '%s\n' "test"
  else
    printf '%s\n' "live"
  fi
}

ensure_backup_dir() {
  mkdir -p "$BACKUP_DIR" 2>/dev/null || true
}

prune_backups() {
  local prefix="$1"
  local count=0
  local old

  [[ "$BACKUP_LIMIT" =~ ^[0-9]+$ ]] || BACKUP_LIMIT=5
  ensure_backup_dir

  while IFS= read -r old; do
    count=$((count + 1))
    if [[ "$count" -gt "$BACKUP_LIMIT" ]]; then
      rm -f "$old" 2>/dev/null || true
    fi
  done < <(ls -1t "$BACKUP_DIR/${prefix}-"*.bak 2>/dev/null || true)
}

backup_current_if_possible() {
  local src="$1"
  local prefix="$2"
  local stamp
  local out

  ensure_backup_dir
  if [[ -f "$src" ]]; then
    stamp="$(date +%Y%m%d-%H%M%S)-$$"
    out="$BACKUP_DIR/${prefix}-${stamp}.bak"
    cp "$src" "$out" 2>/dev/null || true
    prune_backups "$prefix"
  fi
}

set_mode_paths() {
  if [[ "$TEST_MODE" -eq 1 ]]; then
    RESOLV_CONF="$NETMAN_HOME/DEMO"
  fi
}

apply_profile() {
  local profile="$1"
  local profile_path="$CONFIG_DIR/$profile"
  local subnet="unknown"
  local prefix

  if [[ ! -f "$profile_path" ]]; then
    emit_error "profile not found: $profile"
    return 1
  fi

  subnet="$(profile_subnet "$profile" || echo "unknown")"
  prefix="$(backup_prefix)"
  backup_current_if_possible "$RESOLV_CONF" "$prefix"

  if cp "$profile_path" "$RESOLV_CONF" 2>/dev/null; then
    emit_swap "$profile" "$subnet"
    return 0
  fi

  if [[ "$TEST_MODE" -eq 0 ]] && command -v sudo >/dev/null 2>&1; then
    if sudo -n "$APPLIER_CMD" apply "$profile" >/dev/null 2>&1; then
      emit_swap "$profile" "$subnet"
      return 0
    fi
  fi

  emit_error "cannot write $RESOLV_CONF (permission denied)"
  emit_error "fix: run once -> sudo ./setup-passwordless-netman.sh"
  emit_error "or: use --test / NETMAN_RESOLV_CONF to a writable path"
  return 1
}

rollback_profile() {
  local prefix
  local latest_backup=""

  prefix="$(backup_prefix)"
  latest_backup="$(ls -1t "$BACKUP_DIR/${prefix}-"*.bak 2>/dev/null | head -n1 || true)"

  if [[ -n "$latest_backup" ]] && cp "$latest_backup" "$RESOLV_CONF" 2>/dev/null; then
    if [[ "$JSON_MODE" -eq 1 ]]; then
      printf '{"action":"rollback","ok":true,"test":%s}\n' "$( [[ "$TEST_MODE" -eq 1 ]] && echo true || echo false )"
    else
      if [[ "$TEST_MODE" -eq 1 ]]; then
        echo "${C_CYAN}[TEST]${C_RESET} Rolled back."
      else
        echo "Rolled back."
      fi
    fi
    return 0
  fi

  if [[ "$TEST_MODE" -eq 0 ]] && command -v sudo >/dev/null 2>&1; then
    if sudo -n "$APPLIER_CMD" rollback >/dev/null 2>&1; then
      if [[ "$JSON_MODE" -eq 1 ]]; then
        printf '{"action":"rollback","ok":true,"test":false}\n'
      else
        echo "Rolled back."
      fi
      return 0
    fi
  fi

  emit_error "rollback failed (no backup or permission denied)"
  emit_error "fix: run once -> sudo ./setup-passwordless-netman.sh"
  return 1
}

list_command() {
  local profiles=()
  if mapfile -t profiles < <(list_profiles); then
    if [[ "$JSON_MODE" -eq 1 ]]; then
      local out='{"action":"list","profiles":['
      local i
      for i in "${!profiles[@]}"; do
        [[ "$i" -gt 0 ]] && out+=','
        out+="\"$(json_escape "${profiles[$i]}")\""
      done
      out+=']}'; echo "$out"
      return 0
    fi

    printf '%s\n' "${profiles[@]}"
    return 0
  fi

  emit_error "no profiles directory: $CONFIG_DIR"
  return 1
}

edit_command() {
  local profile="$1"
  local profile_path="$CONFIG_DIR/$profile"
  local editor="${EDITOR:-vi}"

  mkdir -p "$CONFIG_DIR"
  touch "$profile_path"

  "$editor" "$profile_path"

  if [[ "$JSON_MODE" -eq 1 ]]; then
    printf '{"action":"edit","profile":"%s"}\n' "$(json_escape "$profile")"
  else
    echo "Edited $profile"
  fi
}

create_command() {
  local name="$1"
  shift
  local subnet=""
  local dns=()
  local path="$CONFIG_DIR/$name"

  case "$name" in
    ""|*[^A-Za-z0-9._-]*)
      emit_error "invalid profile name: $name"
      return 1
      ;;
  esac

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dns)
        [[ $# -ge 2 ]] || { emit_error "missing value for --dns"; return 1; }
        dns+=("$2")
        shift 2
        ;;
      --subnet)
        [[ $# -ge 2 ]] || { emit_error "missing value for --subnet"; return 1; }
        subnet="$2"
        shift 2
        ;;
      *)
        emit_error "unknown create arg: $1"
        return 1
        ;;
    esac
  done

  if [[ "${#dns[@]}" -eq 0 ]]; then
    emit_error "create requires at least one --dns"
    return 1
  fi

  mkdir -p "$CONFIG_DIR"
  {
    echo "# Written by netman"
    echo "# $name profile"
    if [[ -n "$subnet" ]]; then
      echo "# subnet $subnet"
    fi
    echo
    local d
    for d in "${dns[@]}"; do
      echo "nameserver $d"
    done
  } >"$path"

  if [[ "$JSON_MODE" -eq 1 ]]; then
    printf '{"action":"create","profile":"%s","subnet":"%s","dns_count":%s}\n' \
      "$(json_escape "$name")" "$(json_escape "${subnet:-unknown}")" "${#dns[@]}"
  else
    echo "Created $name"
  fi
}

COMMAND="status"
POSITIONAL=()
while [[ $# -gt 0 ]]; do
  if [[ "${#POSITIONAL[@]}" -eq 0 ]]; then
    case "$1" in
      --test)
        TEST_MODE=1
        shift
        continue
        ;;
      --json)
        JSON_MODE=1
        shift
        continue
        ;;
      -h|--help)
        usage
        exit 0
        ;;
    esac
  fi

  POSITIONAL+=("$1")
  shift
done

set_mode_paths

if [[ "${#POSITIONAL[@]}" -eq 0 ]]; then
  current="$(detect_active_profile || echo "custom/unknown")"
  subnet="$( [[ "$current" != "custom/unknown" ]] && profile_subnet "$current" || echo "unknown" )"
  emit_status "$current" "$subnet"
  exit 0
fi

case "${POSITIONAL[0]}" in
  set)
    [[ "${#POSITIONAL[@]}" -eq 2 ]] || { emit_error "usage: netman set <profile>"; exit 1; }
    apply_profile "${POSITIONAL[1]}"
    ;;
  list)
    list_command
    ;;
  edit)
    [[ "${#POSITIONAL[@]}" -eq 2 ]] || { emit_error "usage: netman edit <profile>"; exit 1; }
    edit_command "${POSITIONAL[1]}"
    ;;
  create)
    [[ "${#POSITIONAL[@]}" -ge 2 ]] || { emit_error "usage: netman create <name> --dns <ip> [--dns <ip> ...] [--subnet <cidr>]"; exit 1; }
    create_command "${POSITIONAL[1]}" "${POSITIONAL[@]:2}"
    ;;
  rollback)
    rollback_profile
    ;;
  *)
    emit_error "unknown command: ${POSITIONAL[0]}"
    usage >&2
    exit 1
    ;;
esac
